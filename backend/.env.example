# Backend configuration (all optional)

# Port to listen on. Most hosts (Render/Railway/Fly/Heroku) set this automatically.
PORT=8000

# Comma-separated list of allowed frontend origins for CORS.
# In production set this to your deployed frontend URL, e.g.:
#   CORS_ORIGINS=https://your-app.vercel.app,https://your-app.netlify.app
# Defaults to "*" (any origin) when unset.
CORS_ORIGINS=*

# Optional override for the forecast CSV location.
# Defaults to the bundled copy at backend/data/final_sales_forecast.csv.
# FORECAST_CSV=/absolute/path/to/final_sales_forecast.csv
